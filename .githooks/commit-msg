#!/usr/bin/env bash

# commit-msg hook to enforce Conventional Commits and 50/72 rule.
# This script is designed to be lightweight and dependency-free.

set -euo pipefail

COMMIT_MSG_FILE="$1"
SUBJECT=$(head -n 1 "$COMMIT_MSG_FILE")

# 1. Skip validation for Merge/Revert commits
if echo "$SUBJECT" | grep -qE '^(Merge|Revert)'; then
    exit 0
fi

# 2. Enforce Conventional Commits Pattern
# Types from conductor/workflow.md: feat, fix, docs, style, refactor, test, chore
# Common additional types: perf, build, ci
PATTERN="^(feat|fix|docs|style|refactor|test|chore|perf|build|ci|revert)(\([a-z0-9_-]+\))?!?: .+"
if ! echo "$SUBJECT" | grep -qE "$PATTERN"; then
    echo "❌ ERROR: Invalid Conventional Commit format."
    echo "Expected: <type>(<scope>)?: <description>"
    echo "Allowed types: feat, fix, docs, style, refactor, test, chore, perf, build, ci"
    echo "Example: feat(auth): add login validation"
    exit 1
fi

# 3. Enforce 50/72 Rule - Subject Length (50 chars)
SUBJECT_LEN=${#SUBJECT}
if [ "$SUBJECT_LEN" -gt 50 ]; then
    echo "❌ ERROR: Subject line is too long ($SUBJECT_LEN/50 characters)."
    echo "Summary: $SUBJECT"
    exit 1
fi

# 4. Enforce 50/72 Rule - Blank Line after Subject
# Check if there is more than 1 line
LINE_COUNT=$(wc -l < "$COMMIT_MSG_FILE")
if [ "$LINE_COUNT" -gt 1 ]; then
    SECOND_LINE=$(sed -n '2p' "$COMMIT_MSG_FILE")
    if [ -n "$SECOND_LINE" ]; then
        echo "❌ ERROR: Subject must be followed by a blank line."
        exit 1
    fi
fi

# 5. Enforce 50/72 Rule - Body Line Length (72 chars)
# Skip first two lines (subject and blank line)
# Note: awk line numbers match file lines, but we skip 1,2
LONG_LINES=$(sed '1,2d' "$COMMIT_MSG_FILE" | awk 'length > 72 { print "Line " NR+2 ": " length " chars" }')
if [ -n "$LONG_LINES" ]; then
    echo "❌ ERROR: Body lines must be wrapped at 72 characters."
    echo "$LONG_LINES"
    exit 1
fi

exit 0
