# ── Build Artifacts ──────────────────────────────────────────────────
# Binary caches and build outputs are not text-based and would cause
# the formatter to fail or produce garbled results.
.zig-cache/
zig-out/
zig-pkg/

# ── Binary Data ──────────────────────────────────────────────────────
# These directories contain memory-mapped datasets and binary blobs
# that lack any formattable text content.
data/
resources/*.bin

# ── Build Manifest ───────────────────────────────────────────────────
# build.zig.zon uses Zig's struct literal syntax. Formatting it with
# JSON rules would corrupt the file's semantic structure.
build.zig.zon

# ── Benchmark Artifacts ──────────────────────────────────────────────
# Machine-generated results. Formatting these would create unnecessary
# noise in version control and potentially break automated parsing tools.
results.json
tests/benchmark/results.json
